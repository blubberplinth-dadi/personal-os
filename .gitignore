# Template .gitignore for Task Management System
# Copy relevant parts to your .gitignore

# Personal task files
Tasks/*.md
Tasks/Archive/
!Tasks/.gitkeep
!Tasks/README.md

# Keep templates and examples
!CLAUDE_TEMPLATE.md
!config.example.yaml
!Tasks/example.md
!CRM/example.md

# Binary files
*.pptx

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
.venv/
env/
.env

# IDE & Editor configs
.vscode/
.idea/
.obsidian/
*.swp
*.swo
*~
.DS_Store

# Tool-specific
.specstory/
.factory/

# Logs
*.log
logs/

# Testing
test_*.py
*.test.py
.pytest_cache/
.coverage

# MCP/System
.mcp_cache/
*.pid
*.lock